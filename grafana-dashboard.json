{
  "title": "HP Logical Drive Exporter",
  "tags": ["hp", "ssacli", "storage", "hardware"],
  "timezone": "browser",
  "refresh": "30m",
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Healthy Logical Drives",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "hp_ssacli_logical_drives_healthy_total{job=\"logical_drive_exporter\"}",
          "legendFormat": "Healthy",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed Logical Drives",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "hp_ssacli_logical_drives_failed_total{job=\"logical_drive_exporter\"}",
          "legendFormat": "Failed",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Healthy Physical Drives",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "hp_ssacli_physical_drives_healthy_total{job=\"logical_drive_exporter\"}",
          "legendFormat": "Healthy",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed Physical Drives",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "hp_ssacli_physical_drives_failed_total{job=\"logical_drive_exporter\"}",
          "legendFormat": "Failed",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Logical Drive Status",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "hp_ssacli_logical_drive_status{job=\"logical_drive_exporter\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "UNHEALTHY", "color": "red" },
                      "1": { "text": "HEALTHY", "color": "green" }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "__name__" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "instance" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "controller": "Controller",
              "logicaldrive": "Drive ID",
              "size": "Size",
              "raid_level": "RAID",
              "status_text": "Status",
              "Value": "Health"
            }
          }
        }
      ],
      "options": { "showHeader": true, "footer": { "show": false } }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Physical Drive Status",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "hp_ssacli_physical_drive_status{job=\"logical_drive_exporter\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "UNHEALTHY", "color": "red" },
                      "1": { "text": "HEALTHY", "color": "green" }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "__name__" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "instance" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "controller": "Controller",
              "location": "Location",
              "media": "Media Type",
              "size": "Size",
              "status_text": "Status",
              "Value": "Health"
            }
          }
        }
      ],
      "options": { "showHeader": true, "footer": { "show": false } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Failed Logical Drives Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "hp_ssacli_logical_drives_failed_total{job=\"logical_drive_exporter\"}",
          "legendFormat": "Failed Logical Drives",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Failed Physical Drives Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
