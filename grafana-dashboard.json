          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Scrape Errors",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "hp_ssacli_scrape_errors_total{job=\"logical_drive_exporter\"}",
          "legendFormat": "Errors",
          "datasource": { "type": "prometheus", "uid": "fffgw7acqg3k0d" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
